# DataForSEO credentials
DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here

# API options
DATAFORSEO_LOCATION_CODE=2616
DATAFORSEO_LANGUAGE_CODE=pl
DATAFORSEO_MAX_KEYWORDS=500

# Topical map defaults
DEFAULT_TARGET_KEYWORDS=300
MAX_TARGET_KEYWORDS=500
MAX_CLUSTERS=16

# Usage limits and admin logs
MAX_FREE_SEARCHES=5
LIMIT_BYPASS_IPS=
ADMIN_API_KEY=change_me_strong_password
ADMIN_SESSION_SECRET=change_me_admin_session_secret
ADMIN_AUTH_COOKIE_MAX_AGE=43200
COOKIE_SECURE=false
LOG_DB_PATH=search_logs.db

# Performance
MAP_CACHE_TTL_SECONDS=1200
MAP_CACHE_MAX_ENTRIES=200
